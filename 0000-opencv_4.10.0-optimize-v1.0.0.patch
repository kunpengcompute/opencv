+static inline void handleRow(Vec3b *dst_row, int32x4_t v_sx, int32x4_t v_sy, const Mat &src, const Scalar &borderVal)
+{
+    // vgetq_lane_s32的参数只能是常数，无法使用循环。
+    int sx0 = vgetq_lane_s32(v_sx, 0);
+    int sy0 = vgetq_lane_s32(v_sy, 0);
+    int sx1 = vgetq_lane_s32(v_sx, 1);
+    int sy1 = vgetq_lane_s32(v_sy, 1);
+    int sx2 = vgetq_lane_s32(v_sx, 2);
+    int sy2 = vgetq_lane_s32(v_sy, 2);
+    int sx3 = vgetq_lane_s32(v_sx, 3);
+    int sy3 = vgetq_lane_s32(v_sy, 3);
+    constexpr int j = 0;
+    if (static_cast<unsigned>(sx0) < static_cast<unsigned>(src.rows) &&
+        static_cast<unsigned>(sy0) < static_cast<unsigned>(src.cols)) {
+        dst_row[j] = src.at<cv::Vec3b>(sx0, sy0);
+    } else {
+        dst_row[j] = cv::Vec3b(static_cast<uchar>(borderVal[0]),
+            static_cast<uchar>(borderVal[1]),
+            static_cast<uchar>(borderVal[2]));  // 2
+    }
+    if (static_cast<unsigned>(sx1) < static_cast<unsigned>(src.rows) &&
+        static_cast<unsigned>(sy1) < static_cast<unsigned>(src.cols)) {
+        dst_row[j + 1] = src.at<cv::Vec3b>(sx1, sy1);
+    } else {
+        dst_row[j + 1] = cv::Vec3b(static_cast<uchar>(borderVal[0]),
+            static_cast<uchar>(borderVal[1]),
+            static_cast<uchar>(borderVal[2]));  // 2
+    }
+    if (static_cast<unsigned>(sx2) < static_cast<unsigned>(src.rows) &&
+        static_cast<unsigned>(sy2) < static_cast<unsigned>(src.cols)) {
+        dst_row[j + 2] = src.at<cv::Vec3b>(sx2, sy2);  // 2
+    } else {
+        dst_row[j + 2] = cv::Vec3b(static_cast<uchar>(borderVal[0]),  // 2
+            static_cast<uchar>(borderVal[1]),
+            static_cast<uchar>(borderVal[2]));  // 2
+    }
+    if (static_cast<unsigned>(sx3) < static_cast<unsigned>(src.rows) &&
+        static_cast<unsigned>(sy3) < static_cast<unsigned>(src.cols)) {
+        dst_row[j + 3] = src.at<cv::Vec3b>(sx3, sy3);  // 3
+    } else {
+        dst_row[j + 3] = cv::Vec3b(static_cast<uchar>(borderVal[0]),  // 3
+            static_cast<uchar>(borderVal[1]),
+            static_cast<uchar>(borderVal[2]));  // 2
+    }
+}
