+static void gaussianBlurU8C1BD1xN(const uchar *src_data, size_t srcStep, uchar *dst_data, size_t dstStep, int width,
+    int height, const uint16_t *ky, int ksizeY)
+{
+    int nstripes =
+        std::min(std::max(static_cast<int>(static_cast<float>(height) * width / kpInternal::chunk), 1), height);
+
+#pragma omp parallel for proc_bind(close) num_threads(kpInternal::THREADS)
+    for (int i = 0; i < nstripes; ++i) {
+        int lineStart = static_cast<int>(static_cast<float>(height) / nstripes * i + 0.5);
+        int lineEnd = static_cast<int>(static_cast<float>(height) / nstripes * (i + 1) + 0.5);
+
+        for (int lineNum = lineStart; lineNum < lineEnd; ++lineNum) {
+            uint8x8_t rowUp0;
+            uint8x8_t rowUp1;
+            uint8x8_t rowDown0;
+            uint8x8_t rowDown1;
+            uint16x8_t temp0;
+            uint16x8_t temp1;
+            uint8x8_t result0;
+            uint8x8_t result1;
+            uint16x8_t coef;
+
+            int w = 0;
+            int mid = ksizeY / 2;
+            for (; w < width - 16; w += 16) {  // 16
+                rowUp0 = vld1_u8(src_data + lineNum * srcStep + w * 1);
+                rowUp1 = vld1_u8(src_data + lineNum * srcStep + (w + 8) * 1);  // 8
+                coef = vdupq_n_u16(ky[mid]);
+                temp0 = vmulq_u16(vmovl_u8(rowUp0), coef);
+                temp1 = vmulq_u16(vmovl_u8(rowUp1), coef);
+
+                for (int shift = 1; shift < (ksizeY + 1) / 2; ++shift) {  // 2
+                    int rowUpIndex = abs(lineNum - shift);
+                    int rowDownIndex =
+                        (lineNum + shift < height) ? (lineNum + shift) : (2 * (height - 1) - (lineNum + shift));
+                    rowUp0 = vld1_u8(src_data + rowUpIndex * srcStep + w * 1);
+                    rowUp1 = vld1_u8(src_data + rowUpIndex * srcStep + (w + 8) * 1);  // 8
+                    rowDown0 = vld1_u8(src_data + rowDownIndex * srcStep + w * 1);
+                    rowDown1 = vld1_u8(src_data + rowDownIndex * srcStep + (w + 8) * 1);  // 8
+                    coef = vdupq_n_u16(ky[mid + shift]);
+
+                    temp0 = vmlaq_u16(temp0, vaddq_u16(vmovl_u8(rowUp0), vmovl_u8(rowDown0)), coef);
+                    temp1 = vmlaq_u16(temp1, vaddq_u16(vmovl_u8(rowUp1), vmovl_u8(rowDown1)), coef);
+                }
+
+                result0 = vqrshrn_n_u16(temp0, 8);  // 8
+                result1 = vqrshrn_n_u16(temp1, 8);  // 8
+
+                vst1_u8(dst_data + lineNum * dstStep + w * 1, result0);
+                vst1_u8(dst_data + lineNum * dstStep + (w + 8) * 1, result1);  // 8
+            }
+
+            for (; w < width; ++w) {
+                uint16_t result;
+                const uint8_t *pixelUp;
+                const uint8_t *pixelDown;
+                const uint8_t *pixelMid;
+                uint8_t *dstPixel;
+
+                uint16_t coef_single = ky[mid];
+                pixelMid = src_data + lineNum * srcStep + w * 1;
+                result = coef_single * static_cast<uint16_t>(pixelMid[0]);
+
+                for (int shift = 1; shift < (ksizeY + 1) / 2; ++shift) {  // 2
+                    int rowUpIndex = abs(lineNum - shift);
+                    int rowDownIndex =
+                        (lineNum + shift < height) ? (lineNum + shift) : (2 * (height - 1) - (lineNum + shift));
+                    coef_single = ky[mid + shift];
+                    pixelUp = src_data + rowUpIndex * srcStep + w * 1;
+                    pixelDown = src_data + rowDownIndex * srcStep + w * 1;
+                    result += (static_cast<uint16_t>(pixelUp[0]) + static_cast<uint16_t>(pixelDown[0])) * coef_single;
+                }
+                dstPixel = dst_data + lineNum * dstStep + w * 1;
+                dstPixel[0] = kpInternal::saturatingRoundingShiftRight<uint16_t>(result, 8);  // 8
+            }
+        }
+    }
+}
