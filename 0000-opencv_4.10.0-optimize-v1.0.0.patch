+static int kcv_remap(InputArray _src, OutputArray _dst, InputArray _map1, InputArray _map2, int interpolation, int borderType,
+    const Scalar &borderValue)
+{
+    if (_src.empty()) {
+        return 1;
+    }
+    if (_map1.empty()) {
+        return 1;
+    }
+    if (!(_map2.empty() || (_map2.size() == _map1.size()))) {
+        return 1;
+    }
+    if (!((_map1.type() == CV_32F) && (_map2.type() == CV_32F))) {
+        return 2;
+    }
+    if (borderType != BORDER_CONSTANT) {
+        return 2;
+    }
+    if (!((_src.type() == CV_8UC3) && (interpolation == 1))) {
+        return 2;
+    }
+    const int WARP_RELATIVE_MAP = 32;
+    const bool hasRelativeFlag = ((interpolation & WARP_RELATIVE_MAP) != 0);
+    const int INTER_REMAP_COEF_BITS1 = 15;
+    static RemapFunc linear_tab[2][8] = {{
+        _remapBilinear<_FixedPtCast<int, uchar, INTER_REMAP_COEF_BITS1>, _RemapVec_8u<false>, short, false>,
+        0,
+    }};
+
+    Mat src = _src.getMat();
+    Mat map1 = _map1.getMat();
+    Mat map2 = _map2.getMat();
+    if (!(((map1.type() == CV_32FC2 || map1.type() == CV_16SC2) && map2.empty()) ||
+            (map1.type() == CV_32FC1 && map2.type() == CV_32FC1))) {
+        return 1;
+    }
+    _dst.create(map1.size(), src.type());
+    Mat dst = _dst.getMat();
+    if (dst.data == src.data)
+        src = src.clone();
+
+    interpolation &= ~WARP_RELATIVE_MAP;
+    if (interpolation == INTER_AREA)
+        interpolation = INTER_LINEAR;
+
+    int type = src.type();
+    int depth = CV_MAT_DEPTH(type);
+    RemapFunc ifunc = nullptr;
+    const void *ctab = nullptr;
+    bool fixpt = depth == CV_8U;
+    bool planarInput = false;
+
+    const int relativeOptionIndex = (hasRelativeFlag ? 1 : 0);
+
+    ifunc = linear_tab[relativeOptionIndex][depth];
+
+    ctab = _initInterTab2D(interpolation, fixpt);
+
+    const Mat *m1 = &map1;
+    const Mat *m2 = &map2;
+    planarInput = map1.channels() == 1;
+    _RemapInvoker invoker(src, dst, m1, m2, borderType, borderValue, planarInput, nullptr, ifunc, ctab);
+    kcv_parallel_for(Range(0, dst.rows), invoker, dst.total() / (double)(1 << 15), 32);
+    return 0;
+}
