+static int kcv_threshold(InputArray _src, OutputArray _dst, double thresh, double maxval, int type)
+{
+    if(_src.empty()){
+        return 1;
+    }
+    if(!(CV_MAT_DEPTH(_src.type()) == CV_8U ||
+        CV_MAT_DEPTH(_src.type()) == CV_32F)){
+        return 2;
+    }
+    if(type != THRESH_BINARY){
+        return 2;
+    }
+    if (CV_MAT_DEPTH(_src.type()) == CV_8U)
+        threshold_8U(_src, _dst, thresh, maxval, type);
+    if (CV_MAT_DEPTH(_src.type()) == CV_32F)
+        threshold_32F(_src, _dst, thresh, maxval, type);
+    return 0;
+}
