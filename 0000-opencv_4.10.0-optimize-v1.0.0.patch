+                        if (borderType == BORDER_CONSTANT &&
+                            (sx >= ssize.width || sx + 1 < 0 || sy >= ssize.height || sy + 1 < 0)) {
+                            for (int k = 0; k < cn; k++)
+                                D[k] = cval[k];
+                        } else {
+                            int sx0;
+                            int sx1;
+                            int sy0;
+                            int sy1;
+                            const T *v0;
+                            const T *v1;
+                            const T *v2;
+                            const T *v3;
+                            const AT *w = wtab + FXY[dx] * 4;
+
+                            sx0 = borderInterpolate(sx, ssize.width, borderType);
+                            sy0 = borderInterpolate(sy, ssize.height, borderType);
+                            sx1 = borderInterpolate(sx + 1, ssize.width, borderType);
+                            sy1 = borderInterpolate(sy + 1, ssize.height, borderType);
+                            v3 = sx1 >= 0 && sy1 >= 0 ? S0 + sy1 * sstep + sx1 * cn : &cval[0];
+                            v2 = sx0 >= 0 && sy1 >= 0 ? S0 + sy1 * sstep + sx0 * cn : &cval[0];
+                            v1 = sx1 >= 0 && sy0 >= 0 ? S0 + sy0 * sstep + sx1 * cn : &cval[0];
+                            v0 = sx0 >= 0 && sy0 >= 0 ? S0 + sy0 * sstep + sx0 * cn : &cval[0];
+                            for (int k = 0; k < cn; k++)
+                                D[k] = castOp(WT(w[0] * v0[k] + v1[k] * w[1] + v2[k] * w[2] + v3[k] * w[3]));
+                        }
+                    }
+                }
+            }
+        }
+    }
+}
+
+class _RemapInvoker : public ParallelLoopBody {
+public:
+    _RemapInvoker(const Mat &_src, Mat &_dst, const Mat *_m1, const Mat *_m2, int _borderType,
+        const Scalar &_borderValue, int _planarInput, RemapNNFunc _nnfunc, RemapFunc _ifunc, const void *_ctab)
+        : ParallelLoopBody(), src(&_src), dst(&_dst), m1(_m1), m2(_m2), borderType(_borderType),
+          borderValue(_borderValue), planarInput(_planarInput), nnfunc(_nnfunc), ifunc(_ifunc), ctab(_ctab)
+    {}
+
+    virtual void operator()(const Range &range) const CV_OVERRIDE
+    {
+        int x, y, x1, y1;
+        const int buf_size = 1 << 14;
+        int browsT = std::min(128, dst->rows);
+        int bcols0 = std::min(buf_size / browsT, dst->cols);
+        browsT = std::min(buf_size / bcols0, dst->rows);
+
+        Mat _bufxy(browsT, bcols0, CV_16SC2), _bufa;
+        if (!nnfunc)
+            _bufa.create(browsT, bcols0, CV_16UC1);
+
+        for (y = range.start; y < range.end; y += browsT) {
+            for (x = 0; x < dst->cols; x += bcols0) {
+                int bcols = std::min(bcols0, dst->cols - x);
+                int brows = std::min(browsT, range.end - y);
+                Mat bufa(_bufa, Rect(0, 0, bcols, brows));
+                Mat bufxy(_bufxy, Rect(0, 0, bcols, brows));
+                Mat dpart(*dst, Rect(x, y, bcols, brows));
+
+                for (y1 = 0; y1 < brows; y1++) {
+                    ushort *A = bufa.ptr<ushort>(y1);
+                    short *XY = bufxy.ptr<short>(y1);
+
+                    if (planarInput) {
+                        const float *sY = m2->ptr<float>(y + y1) + x;
+                        const float *sX = m1->ptr<float>(y + y1) + x;
+
+                        x1 = 0;
+                        const int INTER_TAB_MASK = INTER_TAB_SIZE - 1;
+                        float32x4_t v_inter_tab_size_f = vdupq_n_f32((float)INTER_TAB_SIZE);
+                        int32x4_t v_inter_tab_mask = vdupq_n_s32(INTER_TAB_MASK);
+                        int32x4_t v_inter_tab_size = vdupq_n_s32(INTER_TAB_SIZE);
+                        for (; x1 <= bcols - 8; x1 += 8) {
+                            __builtin_prefetch(&sX[x1 + 8], 0, 1);
+                            __builtin_prefetch(&sY[x1 + 8], 0, 1);
+                            float32x4_t sx_f1 = vld1q_f32(&sX[x1]);
+                            float32x4_t sy_f1 = vld1q_f32(&sY[x1]);
+                            float32x4_t sx_f2 = vld1q_f32(&sX[x1 + 4]);
+                            float32x4_t sy_f2 = vld1q_f32(&sY[x1 + 4]);
+                            int32x4_t sx1 = vcvtq_s32_f32(vmulq_f32(sx_f1, v_inter_tab_size_f));
+                            int32x4_t sy1 = vcvtq_s32_f32(vmulq_f32(sy_f1, v_inter_tab_size_f));
+                            int32x4_t sx2 = vcvtq_s32_f32(vmulq_f32(sx_f2, v_inter_tab_size_f));
+                            int32x4_t sy2 = vcvtq_s32_f32(vmulq_f32(sy_f2, v_inter_tab_size_f));
+                            int32x4_t v_sy1 = vandq_s32(sy1, v_inter_tab_mask);
+                            int32x4_t v_sx1 = vandq_s32(sx1, v_inter_tab_mask);
+                            int32x4_t v1 = vmlaq_s32(v_sx1, v_sy1, v_inter_tab_size);
+                            int32x4_t v_sy2 = vandq_s32(sy2, v_inter_tab_mask);
+                            int32x4_t v_sx2 = vandq_s32(sx2, v_inter_tab_mask);
+                            int32x4_t v2 = vmlaq_s32(v_sx2, v_sy2, v_inter_tab_size);
+                            int16x4_t sx_shifted1 = vqshrn_n_s32(sx1, INTER_BITS);
+                            int16x4_t sy_shifted1 = vqshrn_n_s32(sy1, INTER_BITS);
+                            int16x4_t sx_shifted2 = vqshrn_n_s32(sx2, INTER_BITS);
+                            int16x4_t sy_shifted2 = vqshrn_n_s32(sy2, INTER_BITS);
+                            vst2_s16(&XY[x1 * 2], {sx_shifted1, sy_shifted1});
+                            vst1_u16(&A[x1], vqmovn_u32(vreinterpretq_u32_s32(v1)));
+                            vst2_s16(&XY[(x1 + 4) * 2], {sx_shifted2, sy_shifted2});
+                            vst1_u16(&A[x1 + 4], vqmovn_u32(vreinterpretq_u32_s32(v2)));
+                        }
+                        for (; x1 < bcols; x1++) {
+                            int sy = cvRound(sY[x1] * INTER_TAB_SIZE);
+                            int sx = cvRound(sX[x1] * INTER_TAB_SIZE);
+                            XY[x1 * 2] = saturate_cast<short>(sx >> INTER_BITS);
+                            XY[x1 * 2 + 1] = saturate_cast<short>(sy >> INTER_BITS);
+                            int v = (sy & (INTER_TAB_SIZE - 1)) * INTER_TAB_SIZE + (sx & (INTER_TAB_SIZE - 1));
+                            A[x1] = (ushort)v;
+                        }
+                    }
+                }
+                // Invoke the calculation function.
+                ifunc(*src, dpart, bufxy, bufa, ctab, borderType, borderValue, Point(x, y));
+            }
+        }
+    }
+
+private:
+    const Mat *src;
+    Mat *dst;
+    const Mat *m1, *m2;
+    int borderType; // 边界类型
+    Scalar borderValue;
+    int planarInput; // 是否为平面输入
+    RemapNNFunc nnfunc;
+    RemapFunc ifunc;
+    const void *ctab;
+};
+
+static inline void _interpolateLinear(float x, float *coeffs)
+{
+    coeffs[0] = 1.f - x;
+    coeffs[1] = x;
+}
+
+static void _initInterTab1D(int method, float *tab, int tabsz)
+{
+    float scale = 1.f / tabsz;
+    if (method == INTER_LINEAR) {
+        for (int i = 0; i < tabsz; i++, tab += 2) {
+            _interpolateLinear(i * scale, tab);
+        }
+    }
+}
+
+static const void *_initInterTab2D(int method, bool fixpt)
+{
+    static float BilinearTab_f[INTER_TAB_SIZE2][2][2];
+    static short BilinearTab_i[INTER_TAB_SIZE2][2][2];
+    const int INTER_REMAP_COEF_BITS = 15;
+    const int INTER_REMAP_COEF_SCALE = 1 << INTER_REMAP_COEF_BITS;
+    static bool inittab[INTER_MAX + 1] = {false};
+    int ksize = 0;
+    float *tab = nullptr;
+    short *itab = nullptr;
+
+    tab = BilinearTab_f[0][0], itab = BilinearTab_i[0][0], ksize = 2;
+
+    if (!inittab[method]) {
+        AutoBuffer<float> _tab(8 * INTER_TAB_SIZE);
+        int i;
+        int j;
+        int q1;
+        int q2;
+        _initInterTab1D(method, _tab.data(), INTER_TAB_SIZE);
+        for (i = 0; i < INTER_TAB_SIZE; i++)
+            for (j = 0; j < INTER_TAB_SIZE; j++, tab += ksize * ksize, itab += ksize * ksize) {
+                int isum = 0;
+
+                for (q1 = 0; q1 < ksize; q1++) {
+                    float vy = _tab[i * ksize + q1];
+                    for (q2 = 0; q2 < ksize; q2++) {
+                        float v = vy * _tab[j * ksize + q2];
+                        tab[q1 * ksize + q2] = v;
+                        isum += itab[q1 * ksize + q2] = saturate_cast<short>(v * INTER_REMAP_COEF_SCALE);
+                    }
+                }
+
+                if (isum != INTER_REMAP_COEF_SCALE) {
+                    int diff = isum - INTER_REMAP_COEF_SCALE;
+                    int ksize2 = ksize / 2;
+                    int Mk1 = ksize2;
+                    int Mk2 = ksize2;
+                    int mk1 = ksize2;
+                    int mk2 = ksize2;
+                    for (q1 = ksize2; q1 < ksize2 + 2; q1++)
+                        for (q2 = ksize2; q2 < ksize2 + 2; q2++) {
+                            if (itab[q1 * ksize + q2] < itab[mk1 * ksize + mk2])
+                                mk1 = q1, mk2 = q2;
+                            else if (itab[q1 * ksize + q2] > itab[Mk1 * ksize + Mk2])
+                                Mk1 = q1, Mk2 = q2;
+                        }
+                    itab[Mk1 * ksize + Mk2] = (short)(itab[Mk1 * ksize + Mk2] - diff);
+                }
+            }
+        tab -= INTER_TAB_SIZE2 * ksize * ksize;
+        itab -= INTER_TAB_SIZE2 * ksize * ksize;
+        if (method == INTER_LINEAR) {
+            for (i = 0; i < INTER_TAB_SIZE2; i++)
+                for (j = 0; j < 4; j++) {
+                    _BilinearTab_iC4[i][0][j * 2] = BilinearTab_i[i][0][0];
+                    _BilinearTab_iC4[i][0][j * 2 + 1] = BilinearTab_i[i][0][1];
+                    _BilinearTab_iC4[i][1][j * 2] = BilinearTab_i[i][1][0];
+                    _BilinearTab_iC4[i][1][j * 2 + 1] = BilinearTab_i[i][1][1];
+                }
+        }
+        inittab[method] = true;
+    }
+    return fixpt ? static_cast<const void *>(itab) : static_cast<const void *>(tab);
+}
