+                    temp_pixel[2] += (src[(w - shift) * 3 + 2] + src[rightPixelIndex * 3 + 2]) * kx[mid - shift];
+                }
+                dst[w * 3 + 0] = kpInternal::saturatingRoundingShiftRight<uint16_t>(temp_pixel[0], 8);  // 3 8
+                dst[w * 3 + 1] = kpInternal::saturatingRoundingShiftRight<uint16_t>(temp_pixel[1], 8);  // 3 8
+                // 3 8 2
+                dst[w * 3 + 2] = kpInternal::saturatingRoundingShiftRight<uint16_t>(temp_pixel[2], 8);
+            }
+        }
+    }
+    return;
+}
