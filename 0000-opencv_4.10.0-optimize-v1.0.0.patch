+#pragma omp parallel for num_threads(12)
+    for (int i = 0; i <= numPixels - vectorSize; i += vectorSize) {
+        uint8x16_t v_gray = vld1q_u8(src + i);
+        vst3q_u8(dst + i * dstChannels, {v_gray, v_gray, v_gray});
+    }
+
+    src = src + (numPixels / vectorSize) * vectorSize;
+
+    for (int i = (numPixels / vectorSize) * vectorSize; i < numPixels; i++, src++, dst += dstChannels) {
+        dst[0] = dst[1] = dst[2] = src[0];
+    }
+}
+
+// Convert Gray to BGR
+static void Gray2BGR(InputArray _src, OutputArray _dst)
+{
+    ColorConversionHelper<ColorSet<1>, ColorSet<3, 4>, ColorSet<CV_8U, CV_16U, CV_32F>> helper(_src, _dst, 3);
+    Gray2BGR_neon(helper.src.data, helper.dst.data, helper.src.cols * helper.src.rows, 3);
