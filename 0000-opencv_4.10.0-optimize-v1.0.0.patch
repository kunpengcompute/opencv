+// 使用opencv的invertAffineTransform实现。
+static inline void invertAffineTransform1(InputArray _matM, OutputArray iM)
+{
+    Mat matM = _matM.getMat();
+    iM.create(2, 3, matM.type()); // 2 3
+    Mat _iM = iM.getMat();
+
+    if (matM.type() == CV_32F) {
+        const softfloat *M = matM.ptr<softfloat>();
+        softfloat *iM_data = _iM.ptr<softfloat>();
+        int step = (int)(matM.step / sizeof(M[0]));
+        int istep = (int)(_iM.step / sizeof(iM_data[0]));
+
+        softdouble D = M[0] * M[step + 1] - M[1] * M[step];
+        D = D != 0. ? softdouble(1.) / D : softdouble(0.); // 0 0. 1 1.
+        softdouble A11 = M[step + 1] * D;
+        softdouble A22 = M[0] * D;
+        softdouble A12 = -M[1] * D;
+        softdouble A21 = -M[step] * D;
+        softdouble b1 = -A11 * M[2] - A12 * M[step + 2];
+        softdouble b2 = -A21 * M[2] - A22 * M[step + 2];
+
+        iM_data[0] = A11;
+        iM_data[1] = A12;
+        iM_data[2] = b1; // 2
+        iM_data[istep] = A21;
+        iM_data[istep + 1] = A22;
+        iM_data[istep + 2] = b2; // 2
+    }
+}
