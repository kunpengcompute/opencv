+                    coef_single = ky[mid + shift];
+                    pixelUp = src_data + rowUpIndex * srcStep + w * 3;      // 3
+                    pixelDown = src_data + rowDownIndex * srcStep + w * 3;  // 3
+                    result[0] +=
+                        (static_cast<uint16_t>(pixelUp[0]) + static_cast<uint16_t>(pixelDown[0])) * coef_single;
+                    result[1] +=
+                        (static_cast<uint16_t>(pixelUp[1]) + static_cast<uint16_t>(pixelDown[1])) * coef_single;
+                    result[2] +=                                                                                  // 2
+                        (static_cast<uint16_t>(pixelUp[2]) + static_cast<uint16_t>(pixelDown[2])) * coef_single;  // 2
+                }
+                dstPixel = dst_data + lineNum * dstStep + w * 3;                                 // 3
+                dstPixel[0] = kpInternal::saturatingRoundingShiftRight<uint16_t>(result[0], 8);  // 8
+                dstPixel[1] = kpInternal::saturatingRoundingShiftRight<uint16_t>(result[1], 8);  // 8
