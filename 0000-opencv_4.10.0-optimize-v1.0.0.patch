+static void threshold_32F(InputArray _src, OutputArray _dst, double thresh, double maxval, int type)
+{
+    if (type != THRESH_BINARY) {
+        return;
+    }
+    Mat src = _src.getMat();
+    _dst.create(src.size(), src.type());
+    Mat dst = _dst.getMat();
+    const float *srcptr = src.ptr<float>();
+    float *dstptr = dst.ptr<float>();
+    int len = src.total() * src.channels();
+    float32x4_t v_thresh = vdupq_n_f32(thresh);
+    float32x4_t v_maxval = vdupq_n_f32(maxval);
+    float32x4_t v_zero = vdupq_n_f32(0.0f);
+    constexpr int neonStep = 4;  // 4 128/32
+    constexpr int unrollFactor = 4;  // 循环展开因子
+    constexpr int neontmp = neonStep * unrollFactor;
+#pragma omp parallel for schedule(auto) num_threads(48)
+    for (int i = 0; i <= len - neontmp; i += neontmp) {
+        float32x4_t v_src0 = vld1q_f32(srcptr + i + 0 * neonStep);
+        uint32x4_t v_mask0 = vcgtq_f32(v_src0, v_thresh);
+        float32x4_t v_dst0 = vbslq_f32(v_mask0, v_maxval, v_zero);
+        vst1q_f32(dstptr + i + 0 * neonStep, v_dst0);
+
+        float32x4_t v_src1 = vld1q_f32(srcptr + i + 1 * neonStep);
+        uint32x4_t v_mask1 = vcgtq_f32(v_src1, v_thresh);
+        float32x4_t v_dst1 = vbslq_f32(v_mask1, v_maxval, v_zero);
+        vst1q_f32(dstptr + i + 1 * neonStep, v_dst1);
+
+        float32x4_t v_src2 = vld1q_f32(srcptr + i + 2 * neonStep);
+        uint32x4_t v_mask2 = vcgtq_f32(v_src2, v_thresh);
+        float32x4_t v_dst2 = vbslq_f32(v_mask2, v_maxval, v_zero);
+        vst1q_f32(dstptr + i + 2 * neonStep, v_dst2);
+
+        float32x4_t v_src3 = vld1q_f32(srcptr + i + 3 * neonStep);
+        uint32x4_t v_mask3 = vcgtq_f32(v_src3, v_thresh);
+        float32x4_t v_dst3 = vbslq_f32(v_mask3, v_maxval, v_zero);
+        vst1q_f32(dstptr + i + 3 * neonStep, v_dst3);
+    }
+    for (int i = len - len % neonStep; i < len; i++) {
+        dstptr[i] = (srcptr[i] > thresh) ? maxval : 0;
+    }
+}
