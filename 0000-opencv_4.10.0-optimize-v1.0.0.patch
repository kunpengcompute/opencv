+static int kcv_resize(InputArray _src, OutputArray _dst, Size dsize, double inv_scale_x, double inv_scale_y, int interpolation)
+{
+    Size ssize = _src.size();
+    if (_src.empty() || ssize.empty()) {
+        return 1;
+    }
+    if (!((_src.type() == CV_8UC3) || (_src.type() == CV_8UC1))) {
+        return 2;
+    }
+    if (!((interpolation == 0 || interpolation == 1 || interpolation == 2 || interpolation == 6))) {
+        return 2;
+    }
+    if (dsize.empty()) {
+        if (!(inv_scale_x > 0)) {
+            return 1;
+        }
+        if (!(inv_scale_y > 0)) {
+            return 1;
+        }
+        dsize = Size(saturate_cast<int>(ssize.width * inv_scale_x), saturate_cast<int>(ssize.height * inv_scale_y));
+        if (dsize.empty()) {
+            return 1;
+        }
+    } else {
+        inv_scale_x = (double)dsize.width / ssize.width;
+        inv_scale_y = (double)dsize.height / ssize.height;
+        if (!(inv_scale_x > 0)) {
+            return 1;
+        }
+        if (!(inv_scale_y > 0)) {
+            return 1;
+        }
+    }
+
+    if (interpolation == INTER_LINEAR_EXACT && (_src.depth() == CV_32F || _src.depth() == CV_64F)) {
+        interpolation = INTER_LINEAR;
+    }
+    Mat src = _src.getMat();
+    _dst.create(dsize, src.type());
+    Mat dst = _dst.getMat();
+    // dsize == ssize直接返回
+    if (dsize == ssize) {
+        src.copyTo(dst);
+        return 0;
+    }
+
+    resize_(src.type(), src.data, src.step, src.cols, src.rows, dst.data, dst.step, dst.cols, dst.rows, inv_scale_x,
+            inv_scale_y, interpolation);
+    return 0;
+}
+}
