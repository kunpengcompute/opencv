+static int kcv_contourArea(InputArray _contour, double & area, bool oriented = false)
+{
+    if (_contour.empty()) {
+        return 2;
+    }
+    Mat contour = _contour.getMat();
+    int npoints = contour.checkVector(2);
+    if (npoints < 1) {
+        return 2;
+    }
+    double a00 = 0;
+    const Point *ptsi = contour.ptr<Point>();
+
+    const Point *prev = &ptsi[npoints - 1];
+    for (int i = 0; i < npoints; i++) {
+        const Point &p = ptsi[i];
+        a00 += prev->x * p.y - prev->y * p.x;
+        prev = &p;
+    }
+
+    a00 *= 0.5; // 0.5
+    if (!oriented)
+        a00 = std::fabs(a00);
+    area = a00;
+    return 0;
+}
