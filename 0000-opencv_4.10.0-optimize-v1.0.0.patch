+                vshrq_n_s32(vmlaq_s32(vmulq_s32(v_b1, vld1q_s32(S1 + x + 12)), v_b0, vld1q_s32(S0 + x + 12)), 22));
+            uint8x8_t ret1 = vqmovun_s16(vcombine_s16(temp[0], temp[1]));
+            uint8x8_t ret2 = vqmovun_s16(vcombine_s16(temp[2], temp[3]));
+            vst1_u8(dst + x, ret1);
+            vst1_u8(dst + x + 8, ret2);
+        }
+        return x;
+    }
+};
+template <typename T, typename WT, typename AT, int ONE, class VecOp>
+struct _HResizeLinear {
+    using value_type = T;
+    using buf_type = WT;
+    using alpha_type = AT;
+
+    void operator()(const T **src, WT **dst, int count, const int *xofs, const AT *alphax, int swidth, int dwidth,
+                    int cn, int xmin, int xmax) const
+    {
+        int idx;
+        int k;
+        VecOp vecOp;
+
+        int dx0 = vecOp(src, dst, count, xofs, alphax, swidth, dwidth, cn, xmin, xmax);
+        for (k = 0; k <= count - 2; k += 2) {
+            const T *S0 = src[k];
+            const T *S1 = src[k + 1];
+            WT *D0 = dst[k];
+            WT *D1 = dst[k + 1];
+            for (idx = dx0; idx < xmax; idx++) {
+                int isx = xofs[idx];
+                WT a0 = alphax[idx * 2];
+                WT a1 = alphax[idx * 2 + 1];
+                WT t0 = S0[isx] * a0 + S0[isx + cn] * a1;
+                WT t1 = S1[isx] * a0 + S1[isx + cn] * a1;
+                D0[idx] = t0;
+                D1[idx] = t1;
+            }
+            for (; idx < dwidth; idx++) {
+                int isx = xofs[idx];
+                D0[idx] = WT(S0[isx] * ONE);
+                D1[idx] = WT(S1[isx] * ONE);
+            }
+        }
+        for (; k < count; k++) {
+            const T *S = src[k];
+            WT *D = dst[k];
+            for (idx = dx0; idx < xmax; idx++) {
+                int isx = xofs[idx];
+                D[idx] = S[isx] * alphax[idx * 2] + S[isx + cn] * alphax[idx * 2 + 1];
+            }
+            for (; idx < dwidth; idx++) {
+                D[idx] = WT(S[xofs[idx]] * ONE);
+            }
+        }
+    }
+};
+template <typename T, typename WT, typename AT, class CastOp, class VecOp>
+struct _VResizeLinear {
+};
+template <>
+struct _VResizeLinear<uchar, int, short, FixedPtCast1<int, uchar, INTER_RESIZE_COEF_BITS1 * 2>,
+                      _VResizeLinearVec_32s8u> {
+    typedef uchar value_type;
+    typedef int buf_type;
+    typedef short alpha_type;
+
+    void operator()(const buf_type **src, value_type *dst, const alpha_type *betax, int width) const
+    {
+        alpha_type b0 = betax[0];
+        alpha_type b1 = betax[1];
+        const buf_type *S0 = src[0];
+        const buf_type *S1 = src[1];
+        _VResizeLinearVec_32s8u vecOp;
+
+        int x = vecOp(src, dst, betax, width);
+        for (; x < width; x++) {
+            dst[x] = uchar((((b0 * (S0[x] >> 4)) >> 16) + ((b1 * (S1[x] >> 4)) >> 16) + 2) >> 2);
+        }
+    }
+};
