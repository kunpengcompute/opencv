+static void gaussianBlurU8C3BD3x3combine(const uchar *src_data, size_t srcStep, uchar *dst_data, size_t dstStep,
+    int width, int height, const uint16_t *kx, const uint16_t *ky)
+{
+    int nstripes =
+        std::min(std::max(static_cast<int>(static_cast<float>(height) * width / kpInternal::chunk), 1), height);
+
+#pragma omp parallel for proc_bind(close) num_threads(kpInternal::THREADS)
+    for (int i = 0; i < nstripes; ++i) {  // parallel region
+        int lineStart = static_cast<int>(static_cast<float>(height) / nstripes * i + 0.5);
+        int lineEnd = static_cast<int>(static_cast<float>(height) / nstripes * (i + 1) + 0.5);
+
+        const uint8_t *srcRow0;
+        const uint8_t *srcRow1 = src_data + srcStep * lineStart;
+        const uint8_t *srcRow2;
+
+        if (lineStart) {
+            srcRow0 = src_data + srcStep * (lineStart - 1);
+        } else {
+            srcRow0 = src_data + srcStep * (lineStart + 1);
+        }
+
+        if (lineStart == height - 1) {
+            srcRow2 = src_data + srcStep * (lineStart - 1);
+        } else {
+            srcRow2 = src_data + srcStep * (lineStart + 1);
+        }
+
+        for (int lineNum = lineStart; lineNum < lineEnd; ++lineNum) {
+            uint8_t *dst_row = dst_data + dstStep * lineNum;
+            // do horizontal convolution
+            int reminder = width % 8;
+            int tailStart = width - reminder;
+            // first pixel
+            for (int c = 0; c < 3; ++c) {  // 3
+                uint32_t temp0 = (static_cast<uint32_t>(srcRow0[c]) + static_cast<uint32_t>(srcRow2[c])) * ky[0] +
+                                 static_cast<uint32_t>(srcRow1[c]) * ky[1];
+                // first pixel vertical cov
+                uint32_t temp1 =
+                    (static_cast<uint32_t>(srcRow0[c + 3]) + static_cast<uint32_t>(srcRow2[c + 3])) * ky[0] +
+                    static_cast<uint32_t>(srcRow1[c + 3]) * ky[1];
+                // second pixel vertical cov
+                dst_row[c] =
+                    kpInternal::saturatingRoundingShiftRight<uint32_t>(temp0 * kx[1] + temp1 * kx[0] * 2, 16);  // 2 16
+            }
+            // body loop
+            int w = 0;
+            uint16x8x3_t vConvCurr = vGaussianBlur3Naba(srcRow0, srcRow1, srcRow2, w, ky);
+            uint16x8x3_t vConvNext;
+            for (; w < tailStart - 8; w += 8) {                                        // 8
+                __builtin_prefetch(srcRow0 + (w + 8) * 3);                             // 8 3
+                __builtin_prefetch(srcRow1 + (w + 8) * 3);                             // 8 3
+                __builtin_prefetch(srcRow2 + (w + 8) * 3);                             // 8 3
+                vConvNext = vGaussianBlur3Naba(srcRow0, srcRow1, srcRow2, w + 8, ky);  // 8
+                uint8x8x3_t bluredResult = hGaussianBlur3Naba(vConvCurr, vConvNext, kx);
+                vst3_u8(dst_row + (w + 1) * 3, bluredResult);  // 3
+                vConvCurr = vConvNext;
+            }
+            // tail process
+            uint32_t bluredPrev[3];
+            uint32_t bluredCurr[3];
+            uint32_t bluredNext[3];
+            --w;
+            // 3
+            bluredPrev[0] = (static_cast<uint32_t>(srcRow0[w * 3]) + static_cast<uint32_t>(srcRow2[w * 3])) * ky[0] +
+                            static_cast<uint32_t>(srcRow1[w * 3]) * ky[1];  // 3
+            bluredPrev[1] =
+                (static_cast<uint32_t>(srcRow0[w * 3 + 1]) + static_cast<uint32_t>(srcRow2[w * 3 + 1])) * ky[0] +  // 3
+                static_cast<uint32_t>(srcRow1[w * 3 + 1]) * ky[1];                                                 // 3
+            // 2 3
+            bluredPrev[2] = (static_cast<uint32_t>(srcRow0[w * 3 + 2]) + static_cast<uint32_t>(srcRow2[w * 3 + 2])) *
+                                ky[0] +                                         // 2 3
+                            static_cast<uint32_t>(srcRow1[w * 3 + 2]) * ky[1];  // 3 2
+            ++w;
+            // 3
+            bluredCurr[0] = (static_cast<uint32_t>(srcRow0[w * 3]) + static_cast<uint32_t>(srcRow2[w * 3])) * ky[0] +
+                            static_cast<uint32_t>(srcRow1[w * 3]) * ky[1];  // 3
+            bluredCurr[1] =
+                (static_cast<uint32_t>(srcRow0[w * 3 + 1]) + static_cast<uint32_t>(srcRow2[w * 3 + 1])) * ky[0] +  // 3
+                static_cast<uint32_t>(srcRow1[w * 3 + 1]) * ky[1];                                                 // 3
+            bluredCurr[2] =                                                                                        // 2
+                (static_cast<uint32_t>(srcRow0[w * 3 + 2]) + static_cast<uint32_t>(srcRow2[w * 3 + 2])) * // 2 3
+                    ky[0] +                                         // 2 3
+                static_cast<uint32_t>(srcRow1[w * 3 + 2]) * ky[1];  // 3 2
+
+            for (; w < width - 1; ++w) {
+                bluredNext[0] =
+                    (static_cast<uint32_t>(srcRow0[(w + 1) * 3]) + static_cast<uint32_t>(srcRow2[(w + 1) * 3])) *  // 3
+                        ky[0] +
+                    static_cast<uint32_t>(srcRow1[(w + 1) * 3]) * ky[1];                // 3
+                bluredNext[1] = (static_cast<uint32_t>(srcRow0[(w + 1) * 3 + 1]) +      // 3
+                                    static_cast<uint32_t>(srcRow2[(w + 1) * 3 + 1])) *  // 3
+                                    ky[0] +
+                                static_cast<uint32_t>(srcRow1[(w + 1) * 3 + 1]) * ky[1];  // 3
+                bluredNext[2] = (static_cast<uint32_t>(srcRow0[(w + 1) * 3 + 2]) +        // 3 2
+                                    static_cast<uint32_t>(srcRow2[(w + 1) * 3 + 2])) *    // 3 2
+                                    ky[0] +
+                                static_cast<uint32_t>(srcRow1[(w + 1) * 3 + 2]) * ky[1];  // 3 2
+                dst_row[w * 3] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                    bluredCurr[0] * kx[1] + (bluredPrev[0] + bluredNext[0]) * kx[0], 16);  // 3 16
+                dst_row[w * 3 + 1] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                    bluredCurr[1] * kx[1] + (bluredPrev[1] + bluredNext[1]) * kx[0], 16);  // 3 16
+                // 2 3
+                dst_row[w * 3 + 2] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                    bluredCurr[2] * kx[1] + (bluredPrev[2] + bluredNext[2]) * kx[0], 16);  // 3 2 16
+
+                std::copy(bluredCurr, bluredCurr + 3, bluredPrev);  // 3
+                std::copy(bluredNext, bluredNext + 3, bluredCurr);  // 3
+            }
+            // last pixel 3
+            dst_row[w * 3] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                bluredCurr[0] * kx[1] + (bluredPrev[0]) * kx[0] * 2, 16);  // 3 2 16
+            dst_row[w * 3 + 1] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                bluredCurr[1] * kx[1] + (bluredPrev[1]) * kx[0] * 2, 16);  // 3 2 16
+            dst_row[w * 3 + 2] = kpInternal::saturatingRoundingShiftRight<uint32_t>(
+                bluredCurr[2] * kx[1] + (bluredPrev[2]) * kx[0] * 2, 16);  // 3 2 16
+            // next loop value
+            srcRow0 = srcRow1;
+            srcRow1 = srcRow2;
+            if (lineNum + 1 == height - 1) {
+                srcRow2 = srcRow0;
+            } else {
+                srcRow2 = srcRow2 + srcStep * 1;
+            }
+        }
+    }
+}
+
+static void gaussianBlurU8C3BD(const uchar *src_data, size_t srcStep, uchar *dst_data, size_t dstStep, int width,
+    int height, const uint16_t *kx, int ksizeX, const uint16_t *ky, int ksizeY, int cn)
+{
+    // combined method
+    if (ksizeX == 3 && ksizeY == 3 && cn == 3) {  // 3
+        gaussianBlurU8C3BD3x3combine(src_data, srcStep, dst_data, dstStep, width, height, kx, ky);
+        return;
+    } else if (ksizeY == 1 && cn == 3) {  // 3
+        gaussianBlurU8C3BDNx1(src_data, srcStep, dst_data, dstStep, width, height, kx, ksizeX);
+        return;
+    } else if (ksizeY == 1 && cn == 1) {
+        gaussianBlurU8C1BDNx1(src_data, srcStep, dst_data, dstStep, width, height, kx, ksizeX);
+        return;
+    } else if (ksizeX == 1 && cn == 3) {  // 3
+        gaussianBlurU8C3BD1xN(src_data, srcStep, dst_data, dstStep, width, height, ky, ksizeY);
+        return;
+    } else if (ksizeX == 1 && cn == 1) {
+        gaussianBlurU8C1BD1xN(src_data, srcStep, dst_data, dstStep, width, height, ky, ksizeY);
+        return;
+    }
+}
+
+static void KP_ACC_gaussianBlur(const uchar *src_data, size_t srcStep, uchar *dst_data, size_t dstStep, int width, int height,
+    int depth, int cn, size_t marginLeft, size_t marginTop, size_t marginRight, size_t marginBottom, size_t ksizeX,
+    size_t ksizeY, double sigma1, double sigma2, int borderType)
+{
+    std::vector<ufixedpoint16> fkx;
+    std::vector<ufixedpoint16> fky;
+    cv::Size kernel_size(ksizeX, ksizeY);
+    int type = CV_8U;
+    createGaussianKernels(fkx, fky, type, kernel_size, sigma1, sigma2);
+    auto rmZeros = [](std::vector<ufixedpoint16> &vec) {
+        std::size_t n = 0;
+        for (; n < (vec.size() - 1) / 2; n++) {
+            if (vec[n].raw() != 0)
+                break;
+        }
+        if (n != 0) {
+            vec.erase(vec.end() - n, vec.end());
+            vec.erase(vec.begin(), vec.begin() + n);
+        }
+    };
+    rmZeros(fkx);
+    rmZeros(fky);
+    // U8: u_int8_t    C3: cn == 3    BD: Border Default
+    gaussianBlurU8C3BD(src_data,
+        srcStep,
+        dst_data,
+        dstStep,
+        width,
+        height,
+        (const uint16_t *)&fkx[0],
+        (int)fkx.size(),
+        (const uint16_t *)&fky[0],
+        (int)fky.size(),
+        cn);
+    (void)marginLeft;
+    (void)marginTop;
+    (void)marginRight;
+    (void)marginBottom;
+    (void)depth;
+    (void)borderType;
+}
+
+static inline bool IsSupportedGaussianBlurU8(
+    int ksizeX, int ksizeY, int borderType, int cn, int depth, int width, int height)
+{
+    if (borderType == BORDER_DEFAULT && depth == CV_8U && ((ksizeX % 2) == 1) && ((ksizeY % 2) == 1)) {  // 2
+        if (ksizeX > 10 && ksizeY == 1 && (cn == 3 || cn == 1) && width > ksizeX) {                 // 3 10
+            return true;
+        }
+        if (ksizeX == 1 && ksizeY > 10 && (cn == 3 || cn == 1) && height > ksizeY) {  // 3 10
+            return true;
+        }
+        if (width > ksizeX && height > ksizeY && cn == 3) {  // 3
+            if (ksizeX == 3 && ksizeY == 3) {
+                return true;  // 3
+            }
+        }
+        return false;
+    }
+    return false;
+}
+
+static int kcv_GaussianBlur(InputArray _src, OutputArray _dst, Size ksize, double sigma1, double sigma2, int borderType)
+{
+    if (_src.empty()) {
+        return 1;
+    }
+    Size size = _src.size();
+    bool isSupport = IsSupportedGaussianBlurU8(ksize.width, ksize.height, borderType,
+        CV_MAT_CN(_src.type()), CV_MAT_DEPTH(_src.type()), size.width, size.height);
+    if (!isSupport) {
+        return 2;
+    }
+    int type = _src.type();
+    _dst.create(size, type);
+    if ((borderType & ~BORDER_ISOLATED) != BORDER_CONSTANT &&
+        ((borderType & BORDER_ISOLATED) != 0 || !_src.getMat().isSubmatrix())) {
+        if (size.height == 1)
+            ksize.height = 1;
+        if (size.width == 1)
+            ksize.width = 1;
+    }
+    if (ksize.width == 1 && ksize.height == 1) {
+        _src.copyTo(_dst);
+        return 0;
+    }
+    if (sigma2 <= 0) {
+        sigma2 = sigma1;
+    }
+    int sdepth = CV_MAT_DEPTH(type);
+    int cn = CV_MAT_CN(type);
+    Mat kx;
+    Mat ky;
+    Mat src = _src.getMat();
+    Mat dst = _dst.getMat();
+    Size wsz(src.cols, src.rows);
+    Point ofs;
+    if (!(borderType & BORDER_ISOLATED))
+        src.locateROI(wsz, ofs);
+    if (sdepth == CV_8U && ((borderType & BORDER_ISOLATED) || !_src.isSubmatrix())) {
+        if (src.data == dst.data)
+            src = src.clone();
+        KP_ACC_gaussianBlur(src.ptr(), src.step, dst.ptr(), dst.step, src.cols, src.rows,
+            sdepth, cn, ofs.x, ofs.y, wsz.width - src.cols - ofs.x,
+            wsz.height - src.rows - ofs.y, ksize.width, ksize.height, sigma1, sigma2,
+            borderType & ~BORDER_ISOLATED);
+    }
+    return 0;
+}
+
