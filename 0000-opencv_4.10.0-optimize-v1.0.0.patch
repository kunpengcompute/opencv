+constexpr int BLOCK_SIZE1 = 8;   // 分块矩阵块大小
+enum class BlockRow : uint8_t {
+    BLOCK_ROW0,
+    BLOCK_ROW1,
+    BLOCK_ROW2,
+    BLOCK_ROW3,
+    BLOCK_ROW4,
+    BLOCK_ROW5,
+    BLOCK_ROW6,
+    BLOCK_ROW7,
+};
+
+static void TransposeLeftrow(cv::Mat& src, cv::Mat& dst, int startRow, int startCol)
+{
+    for (int i = startRow; i < src.rows; i++) {
+        for (int j = startCol; j < startCol + BLOCK_SIZE1 && j < src.cols; j++) {
+            dst.at<uint8_t>(j, i) = src.at<uint8_t>(i, j);
+        }
+    }
+}
+
+static void TransposeLeftcol(cv::Mat& src, cv::Mat& dst, int startRow, int startCol)
+{
+    for (int i = startRow; i < startRow + BLOCK_SIZE1 && i < src.rows; i++) {
+        for (int j = startCol; j < src.cols; j++) {
+            dst.at<uint8_t>(j, i) = src.at<uint8_t>(i, j);
+        }
+    }
+}
+
+static void TransposeCorner(cv::Mat& src, cv::Mat& dst, int startRow, int startCol)
+{
+    for (int i = startRow; i < src.rows; i++) {
+        for (int j = startCol; j < src.cols; j++) {
+            dst.at<uint8_t>(j, i) = src.at<uint8_t>(i, j);
+        }
+    }
+}
+static void transposeNeon(cv::Mat& src, cv::Mat& dst, int i, int j)
+{
+    int row = src.rows;
+    int col = src.cols;
+
+    // 数据载入neon寄存器
+    uint8x8_t row0 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW0)) * col + j);
+    uint8x8_t row1 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW1)) * col + j);
+    uint8x8_t row2 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW2)) * col + j);
+    uint8x8_t row3 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW3)) * col + j);
+    uint8x8_t row4 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW4)) * col + j);
+    uint8x8_t row5 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW5)) * col + j);
+    uint8x8_t row6 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW6)) * col + j);
+    uint8x8_t row7 = vld1_u8(src.data + (i + static_cast<uint8_t>(BlockRow::BLOCK_ROW7)) * col + j);
+    // 第一次交叉存取
+    uint8x8x2_t t0 = vtrn_u8(row0, row1);
+    uint8x8x2_t t1 = vtrn_u8(row2, row3);
+    uint8x8x2_t t2 = vtrn_u8(row4, row5);
+    uint8x8x2_t t3 = vtrn_u8(row6, row7);
+    // 通过类型转换绑定数据并进行第二次交叉存取
+    uint16x4x2_t tt0 = vtrn_u16(vreinterpret_u16_u8(t0.val[0]), vreinterpret_u16_u8(t1.val[0]));
+    uint16x4x2_t tt1 = vtrn_u16(vreinterpret_u16_u8(t0.val[1]), vreinterpret_u16_u8(t1.val[1]));
+    uint16x4x2_t tt2 = vtrn_u16(vreinterpret_u16_u8(t2.val[0]), vreinterpret_u16_u8(t3.val[0]));
+    uint16x4x2_t tt3 = vtrn_u16(vreinterpret_u16_u8(t2.val[1]), vreinterpret_u16_u8(t3.val[1]));
+    // 通过类型转换绑定数据并进行第三次交叉存取
+    uint32x2x2_t ttt0 = vtrn_u32(vreinterpret_u32_u16(tt0.val[0]), vreinterpret_u32_u16(tt2.val[0]));
+    uint32x2x2_t ttt1 = vtrn_u32(vreinterpret_u32_u16(tt0.val[1]), vreinterpret_u32_u16(tt2.val[1]));
+    uint32x2x2_t ttt2 = vtrn_u32(vreinterpret_u32_u16(tt1.val[0]), vreinterpret_u32_u16(tt3.val[0]));
+    uint32x2x2_t ttt3 = vtrn_u32(vreinterpret_u32_u16(tt1.val[1]), vreinterpret_u32_u16(tt3.val[1]));
+    // 寄存器数据写入内存
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW0)) * row + i, vreinterpret_u8_u32(ttt0.val[0]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW1)) * row + i, vreinterpret_u8_u32(ttt2.val[0]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW2)) * row + i, vreinterpret_u8_u32(ttt1.val[0]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW3)) * row + i, vreinterpret_u8_u32(ttt3.val[0]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW4)) * row + i, vreinterpret_u8_u32(ttt0.val[1]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW5)) * row + i, vreinterpret_u8_u32(ttt2.val[1]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW6)) * row + i, vreinterpret_u8_u32(ttt1.val[1]));
+    vst1_u8(dst.data + (j + static_cast<uint8_t>(BlockRow::BLOCK_ROW7)) * row + i, vreinterpret_u8_u32(ttt3.val[1]));
+}
+
+static int kcv_transpose(InputArray _src, OutputArray _dst)
+{
+    Mat src = _src.getMat();
+    _dst.create(src.cols, src.rows, src.type());
+    Mat dst = _dst.getMat();
+    // 输入参数检验
+    if (_src.empty()) {
+        return 1;
+    }
+    if (src.data == nullptr) {
+        return 1;
+    }
+    if (src.type() != CV_8U) {
+        return 2;
+    }
+    int row = src.rows;
+    int col = src.cols;
+    int rowStart = row - (row % BLOCK_SIZE1);
+    int colStart = col - (col % BLOCK_SIZE1);
+    // 并行按8x8大小分块转置矩阵
+#pragma omp parallel for num_threads(10)
+    for (int i = 0; i < row; i += BLOCK_SIZE1) {
+        for (int j = 0; j < col; j += BLOCK_SIZE1) {
+            if (row - i >= BLOCK_SIZE1 && col - j >= BLOCK_SIZE1) {
+                transposeNeon(src, dst, i, j);
+            }
+        }
+    }
+    // 处理剩余部分
+    if (row % BLOCK_SIZE1 != 0) {
+        for (int j = 0; j < col; j += BLOCK_SIZE1) {
+            TransposeLeftrow(src, dst, rowStart, j);
+        }
+    }
+    if (col % BLOCK_SIZE1 != 0) {
+        for (int i = 0; i < row; i += BLOCK_SIZE1) {
+            TransposeLeftcol(src, dst, i, colStart);
+        }
+    }
+    if (row % BLOCK_SIZE1 != 0 && col % BLOCK_SIZE1 != 0) {
+        TransposeCorner(src, dst, rowStart, colStart);
+    }
+    return 0;
+}
 
