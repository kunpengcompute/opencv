+template <typename HResize, typename VResize>
+class _resizeGeneric_Invoker {
+public:
+    using T = typename HResize::value_type;
+    using WT = typename HResize::buf_type;
+    using AT = typename HResize::alpha_type;
+
+    _resizeGeneric_Invoker(const Mat &_src, Mat &_dst, const int *_xofs, const int *_yofs, const AT *_alpha,
+                           const AT *__beta, const Size &_ssize, const Size &_dsize, int _ksize, int _xmin, int _xmax)
+        : src(_src),
+          dst(_dst),
+          xofs(_xofs),
+          yofs(_yofs),
+          alphax(_alpha),
+          _beta(__beta),
+          ssize(_ssize),
+          dsize(_dsize),
+          ksize(_ksize),
+          xmin(_xmin),
+          xmax(_xmax)
+    {
+    }
+    void operator()(const Range &range) const
+    {
+        int cn = src.channels();
+        int bufstep = (int)alignSize(dsize.width, 16);
+
+#pragma omp parallel num_threads(20)
+        {
+            HResize hresize;
+            VResize vresize;
+
+            AutoBuffer<WT> _buffer(bufstep * ksize);
+            const T *srows[MAX_ESIZE1] = {0};
+            WT *rows[MAX_ESIZE1] = {0};
+            int prev_sy[MAX_ESIZE1];
+
+            for (int k = 0; k < ksize; k++) {
+                prev_sy[k] = -1;
+                rows[k] = _buffer.data() + bufstep * k;
+            }
+
+#pragma omp for schedule(auto)
+            for (int idy = range.start; idy < range.end; idy++) {
+                const AT *betax = _beta + ksize * idy;
+                int sy0 = yofs[idy];
+                int k0 = ksize;
+                int k1 = 0;
+                int ksize3 = ksize / 2;
+
+                for (int k = 0; k < ksize; k++) {
+                    int isy = _clip(sy0 - ksize3 + 1 + k, 0, ssize.height);
+                    for (k1 = std::max(k1, k); k1 < ksize; k1++) {
+                        if (k1 < MAX_ESIZE1 && isy == prev_sy[k1]) {
+                            if (k1 > k)
+                                memcpy(rows[k], rows[k1], bufstep * sizeof(rows[0][0]));
+                            break;
+                        }
+                    }
+                    if (k1 == ksize) {
+                        k0 = std::min(k0, k);
+                    }
+                    srows[k] = src.template ptr<T>(isy);
+                    prev_sy[k] = isy;
+                }
+
+                if (k0 < ksize)
+                    hresize((const T **)(srows + k0), (WT **)(rows + k0), ksize - k0, xofs, (const AT *)(alphax),
+                            ssize.width, dsize.width, cn, xmin, xmax);
+                vresize((const WT **)rows, (T *)(dst.data + dst.step * idy), betax, dsize.width);
+            }
+        }
+    }
+
+private:
+    Mat src;
+    Mat dst;
+    const int *xofs, *yofs;
+    const AT *alphax, *_beta;
+    Size ssize, dsize;
+    const int ksize, xmin, xmax;
+
+    _resizeGeneric_Invoker &operator=(const _resizeGeneric_Invoker &);
+    _resizeGeneric_Invoker(const _resizeGeneric_Invoker& other);
+};
+
+template <class HResize, class VResize>
+static void _resizeGeneric_(const Mat &src, Mat &dst, const int *xofs, const void *_alpha, const int *yofs,
+                            const void *_beta, int xmin, int xmax, int ksize)
+{
+    using AT = typename HResize::alpha_type;
+    const AT *betax = static_cast<const AT *>(_beta);
+    Size ssize = src.size();
+    Size dsize = dst.size();
+    int cn = src.channels();
+    ssize.width *= cn;
+    dsize.width *= cn;
+    xmin *= cn;
+    xmax *= cn;
+
+    Range range(0, dsize.height);
+    _resizeGeneric_Invoker<HResize, VResize> invoker(src, dst, xofs, yofs, (const AT *)_alpha, betax, ssize, dsize,
+                                                     ksize, xmin, xmax);
+    invoker(range);
+}
+class _resizeNN_bitexactInvoker : public ParallelLoopBody {
+public:
+    _resizeNN_bitexactInvoker(const Mat &_src, Mat &_dst, int *_xOffset, int _ify, int _ify0)
+        : src(_src),
+          dst(_dst),
+          xOffset(_xOffset),
+          ify(_ify),
+          ify0(_ify0)
+    {
+    }
+
+    virtual void operator()(const Range &range) const CV_OVERRIDE
+    {
+        Size ssize = src.size();
+        Size dsize = dst.size();
+        int pix_size = (int)src.elemSize();
+#pragma omp parallel for num_threads(12)
+        for (int y = range.start; y < range.end; y++) {
+            int x = 0;
+            int _sy = (ify * y + ify0) >> 16;
+            uchar *D = dst.ptr(y);
+            int isy = std::min(_sy, ssize.height - 1);
+            const uchar *S = src.ptr(isy);
+            switch (pix_size) {
+                case 3:
+#if (CV_SIMD || CV_SIMD_SCALABLE)
+                    for (; x <= dsize.width - 8; x += 8, D += 24) {
+                        uint8x8_t _tS0 = vld1_u8(S + xOffset[x + 0] * 3);
+                        uint8x8_t _tS1 = vld1_u8(S + xOffset[x + 1] * 3);
+                        uint8x8_t _tS2 = vld1_u8(S + xOffset[x + 2] * 3);
+                        uint8x8_t _tS3 = vld1_u8(S + xOffset[x + 3] * 3);
+                        uint8x8_t _tS4 = vld1_u8(S + xOffset[x + 4] * 3);
+                        uint8x8_t _tS5 = vld1_u8(S + xOffset[x + 5] * 3);
+                        uint8x8_t _tS6 = vld1_u8(S + xOffset[x + 6] * 3);
+                        uint8x8_t _tS7 = vld1_u8(S + xOffset[x + 7] * 3);
+
+                        vst1_u8(D, _tS0);
+                        vst1_u8(D + 3, _tS1);
+                        vst1_u8(D + 6, _tS2);
+                        vst1_u8(D + 9, _tS3);
+                        vst1_u8(D + 12, _tS4);
+                        vst1_u8(D + 15, _tS5);
+                        D[18] = vget_lane_u8(_tS6, 0);
+                        D[19] = vget_lane_u8(_tS6, 1);
+                        D[20] = vget_lane_u8(_tS6, 2);
+                        D[21] = vget_lane_u8(_tS7, 0);
+                        D[22] = vget_lane_u8(_tS7, 1);
+                        D[23] = vget_lane_u8(_tS7, 2);
+                    }
+#endif
+                    for (; x < dsize.width; x++, D += 3) {
+                        const uchar *_tS = S + xOffset[x] * 3;
+                        D[0] = _tS[0];
+                        D[1] = _tS[1];
+                        D[2] = _tS[2];
+                    }
+                    break;
+                default:
+                    for (x = 0; x < dsize.width; x++, D += pix_size) {
+                        const uchar *_tS1 = S + xOffset[x] * pix_size;
+                        for (int j = 0; j < pix_size; j++)
+                            D[j] = _tS1[j];
+                    }
+            }
+        }
+    }
+
+private:
+    const Mat &src;
+    Mat &dst;
+    int *xOffset; // Offset
+    const int ify;
+    const int ify0;
+};
+static void _resizeNN_bitexact(const Mat &src, Mat &dst, double /* ifx */, double /* ify */)
+{
+    Size ssize = src.size();
+    Size dsize = dst.size();
+    int ifx = ((ssize.width << 16) + dsize.width / 2) / dsize.width;  // 16bit fixed-point arithmetic
+    int ifx0 = ifx / 2 - ssize.width % 2;  // This method uses center pixel coordinate as Pillow and scikit-images do.
+    int ify = ((ssize.height << 16) + dsize.height / 2) / dsize.height;
+    int ify0 = ify / 2 - ssize.height % 2;
+
+    std::vector<int> xOffset(dsize.width * 16, 0);
+
+    for (int x = 0; x < dsize.width; x++) {
+        int isx = (ifx * x + ifx0) >> 16;
+        xOffset[x] = std::min(isx, ssize.width - 1);  // offset in element (not byte)
+    }
+    Range range(0, dsize.height);
+    _resizeNN_bitexactInvoker invoker(src, dst, xOffset.data(), ify, ify0);
+    invoker(range);
+}
