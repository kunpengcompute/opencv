+static inline uint8x8x3_t hGaussianBlur3Naba(
+    const uint16x8x3_t rgb_current, const uint16x8x3_t rgb_next, const uint16_t *kx)
+{
+    uint8x8x3_t bluredResult;
+
+    uint16x8x3_t rgb_p1;
+    uint16x8x3_t rgb_p2;
+    uint16x8x3_t rgb_p3;
+
+    uint16x4_t kmid = vdup_n_u16(kx[1]);
+    uint16x4_t kside = vdup_n_u16(kx[0]);
+
+    rgb_p1 = rgb_current;
+    rgb_p2.val[0] = vextq_u16(rgb_current.val[0], rgb_next.val[0], 1);
+    rgb_p2.val[1] = vextq_u16(rgb_current.val[1], rgb_next.val[1], 1);
+    rgb_p2.val[2] = vextq_u16(rgb_current.val[2], rgb_next.val[2], 1);  // 2
+    rgb_p3.val[0] = vextq_u16(rgb_current.val[0], rgb_next.val[0], 2);  // 2
+    rgb_p3.val[1] = vextq_u16(rgb_current.val[1], rgb_next.val[1], 2);  // 2
+    rgb_p3.val[2] = vextq_u16(rgb_current.val[2], rgb_next.val[2], 2);  // 2
+
+    bluredResult.val[0] = gaussianBlurU8C3BD1x3Kernal(rgb_p1.val[0], rgb_p2.val[0], rgb_p3.val[0], kside, kmid, kside);
+    bluredResult.val[1] = gaussianBlurU8C3BD1x3Kernal(rgb_p1.val[1], rgb_p2.val[1], rgb_p3.val[1], kside, kmid, kside);
+    bluredResult.val[2] =                                                                              // 2
+        gaussianBlurU8C3BD1x3Kernal(rgb_p1.val[2], rgb_p2.val[2], rgb_p3.val[2], kside, kmid, kside);  // 2
+
+    return bluredResult;
+}
