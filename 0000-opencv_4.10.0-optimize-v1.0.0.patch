+                temp1.val[2] = vmulq_u16(vmovl_u8(rowUp1.val[2]), coef);  // 2
+
+                for (int shift = 1; shift < (ksizeY + 1) / 2; ++shift) {  // 2
+                    int rowUpIndex = abs(lineNum - shift);
+                    int rowDownIndex =
+                        (lineNum + shift < height) ? (lineNum + shift) : (2 * (height - 1) - (lineNum + shift));
+                    rowUp0 = vld3_u8(src_data + rowUpIndex * srcStep + w * 3);            // 3
+                    rowUp1 = vld3_u8(src_data + rowUpIndex * srcStep + (w + 8) * 3);      // 8 3
+                    rowDown0 = vld3_u8(src_data + rowDownIndex * srcStep + w * 3);        // 3
+                    rowDown1 = vld3_u8(src_data + rowDownIndex * srcStep + (w + 8) * 3);  // 8 3
+                    coef = vdupq_n_u16(ky[mid + shift]);
+
+                    temp0.val[0] =
+                        vmlaq_u16(temp0.val[0], vaddq_u16(vmovl_u8(rowUp0.val[0]), vmovl_u8(rowDown0.val[0])), coef);
+                    temp0.val[1] =
+                        vmlaq_u16(temp0.val[1], vaddq_u16(vmovl_u8(rowUp0.val[1]), vmovl_u8(rowDown0.val[1])), coef);
+                    // 2
+                    temp0.val[2] = vmlaq_u16(
+                        temp0.val[2], vaddq_u16(vmovl_u8(rowUp0.val[2]), vmovl_u8(rowDown0.val[2])), coef);  // 2
+                    temp1.val[0] =
+                        vmlaq_u16(temp1.val[0], vaddq_u16(vmovl_u8(rowUp1.val[0]), vmovl_u8(rowDown1.val[0])), coef);
+                    temp1.val[1] =
+                        vmlaq_u16(temp1.val[1], vaddq_u16(vmovl_u8(rowUp1.val[1]), vmovl_u8(rowDown1.val[1])), coef);
+                    // 2
+                    temp1.val[2] = vmlaq_u16(
+                        temp1.val[2], vaddq_u16(vmovl_u8(rowUp1.val[2]), vmovl_u8(rowDown1.val[2])), coef);  // 2
+                }
+
+                result0.val[0] = vqrshrn_n_u16(temp0.val[0], 8);  // 8
+                result0.val[1] = vqrshrn_n_u16(temp0.val[1], 8);  // 8
+                result0.val[2] = vqrshrn_n_u16(temp0.val[2], 8);  // 8 2
+                result1.val[0] = vqrshrn_n_u16(temp1.val[0], 8);  // 8
+                result1.val[1] = vqrshrn_n_u16(temp1.val[1], 8);  // 8
+                result1.val[2] = vqrshrn_n_u16(temp1.val[2], 8);  // 8 2
