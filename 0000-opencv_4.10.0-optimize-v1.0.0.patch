+        case COLOR_RGB2BGR:  // case COLOR_BGR2RGB: both are identical, no need to define separately
+            RGB2RGB(_src, _dst);
+            break;
+        case COLOR_GRAY2BGR:
+            Gray2BGR(_src, _dst);
+            break;
+        default:
