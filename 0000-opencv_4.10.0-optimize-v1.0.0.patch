 {
+    int retcode = kcv_transpose(_src, _dst);
+    if(retcode == 0 || retcode == 1){
+        return;
+    }
     CV_INSTRUMENT_REGION();
 
     int type = _src.type(), esz = CV_ELEM_SIZE(type);
