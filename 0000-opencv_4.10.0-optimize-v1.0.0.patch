+    for (int i = numPixels - numPixels % 8; i < numPixels; i++) {
+        gray[i] = static_cast<uint8_t>(0.114 * bgr[i * 3] + 0.587 * bgr[1 + i * 3] + 0.299 * bgr[2 + i * 3]);
