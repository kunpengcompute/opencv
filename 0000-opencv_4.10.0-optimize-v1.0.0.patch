+/* ================================   parallel_for_  ================================ */
+
+static void kcv_parallel_for_impl(
+    const cv::Range &range, const cv::ParallelLoopBody &body, double nstripes, int nthreads);  // forward declaration
+static void kcv_parallel_for(const cv::Range &range, const cv::ParallelLoopBody &body, double nstripes, int nthreads)
+{
+    if (range.empty()) {
+        return;
+    }
+    static std::atomic<bool> flagNestedParallelFor(false);
+    bool nNesReg = !flagNestedParallelFor.load();
+    if (nNesReg) {
+        nNesReg = !flagNestedParallelFor.exchange(true);
+    }
+    if (nNesReg) {
+        try {
+            kcv_parallel_for_impl(range, body, nstripes, nthreads);
+            flagNestedParallelFor = false;
+        } catch (...) {
+            flagNestedParallelFor = false;
+            throw;
+        }
+    } else {
+        CV_UNUSED(nstripes);
+        body(range);
+    }
+}
+
+static void kcv_parallel_for_impl(
+    const cv::Range &range, const cv::ParallelLoopBody &body, double nstripes, int nthreads)
+{
+
+
+    if ((nthreads < 0 || nthreads > 1) && range.end - range.start > 1) {
+        ParallelLoopBodyWrapperContext context(body, range, nstripes);
+        ProxyLoopBody pbody(context);
+        cv::Range stripeRange = pbody.stripeRange();
+        if (stripeRange.end - stripeRange.start == 1) {
+            body(range);
+            return;
+        }
+
+#pragma omp parallel for schedule(dynamic) num_threads(std::abs(nthreads))
+        for (int i = stripeRange.start; i < stripeRange.end; ++i)
+            pbody(Range(i, i + 1));
+
+        context.finalize();  // propagate exceptions if exists
+        return;
+    }
+
+    body(range);
+}
