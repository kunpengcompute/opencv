+        } else {
+            for (k = 0; k < ksize; k++)
+                alphax[idx * cn * ksize + k] = cbuf[k];
+            for (; k < cn * ksize; k++)
+                alphax[idx * cn * ksize + k] = alphax[idx * cn * ksize + k - ksize];
+        }
+    }
+
+    for (idy = 0; idy < dsize.height; idy++) {
+        if (!area_mode) {
+            ify = (float)((idy + 0.5) * scale_y - 0.5);  // 0.5是为了对齐调整坐标
+            isy = cvFloor(ify);
+            ify -= isy;
+        } else {
+            isy = cvFloor(idy * scale_y);
+            ify = (float)((idy + 1) - (isy + 1) * inv_scale_y);
+            ify = ify <= 0 ? 0.f : ify - cvFloor(ify);
