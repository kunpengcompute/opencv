+static void _resizeNN(const Mat &src, Mat &dst, double fx, double fy)
+{
+    Size ssize = src.size();
+    Size dsize = dst.size();
+
+    AutoBuffer<int> _x_ofs(dsize.width);
+    int* xOfs = _x_ofs.data();
+    double ifx1 = 1. / fx;
+    double ify1 = 1. / fy;
+    for (int x = 0; x < dsize.width; ++x) {
+        int sx = cvFloor(x * ifx1);
+        xOfs[x] = std::min(sx, ssize.width-1);
+    }
+
+    Range range(0, dsize.height);
+    _resizeNNInvoker invoker(src, dst, xOfs, ify1);
+    invoker(range);
+}
+
+static void resize_(int src_type, const uchar *src_data, size_t src_step, int src_width, int src_height, uchar *dst_data,
+             size_t dst_step, int dst_width, int dst_height, double inv_scale_x, double inv_scale_y, int interpolation)
+{
+    if (inv_scale_x < DBL_EPSILON || inv_scale_y < DBL_EPSILON) {
+        inv_scale_x = static_cast<double>(dst_width) / src_width;
+        inv_scale_y = static_cast<double>(dst_height) / src_height;
+    }
+
+    int depth = CV_MAT_DEPTH(src_type);
+    int cn = CV_MAT_CN(src_type);
+    Size dsize = Size(saturate_cast<int>(src_width * inv_scale_x), saturate_cast<int>(src_height * inv_scale_y));
+
+    static ResizeFunc linear_tab[] = {
+        _resizeGeneric_<_HResizeLinear<uchar, int, short, INTER_RESIZE_COEF_SCALE1, HResizeLinearVec_8u32s1>,
+                        _VResizeLinear<uchar, int, short, FixedPtCast1<int, uchar, INTER_RESIZE_COEF_BITS1 * 2>,
+                                       _VResizeLinearVec_32s8u>>};
+
+    static ResizeFunc cubic_tab[] = {
+        _resizeGeneric_<_HResizeCubic<uchar, int, short, _HResizeCubicU8>,
+                        _VResizeCubic<uchar, int, short, FixedPtCast1<int, uchar, INTER_RESIZE_COEF_BITS1 * 2>,
+                                      _VResizeCubicVec_32s8u>>};
+
+    double scale_x = 1. / inv_scale_x;
+    double scale_y = 1. / inv_scale_y;
+
+    Mat src(Size(src_width, src_height), src_type, const_cast<uchar *>(src_data), src_step);
+    Mat dst(dsize, src_type, dst_data, dst_step);
+
+    if (interpolation == INTER_NEAREST_EXACT) {
+        _resizeNN_bitexact(src, dst, inv_scale_x, inv_scale_y);
+        return;
+    }
+    if (interpolation == INTER_NEAREST) {
+        _resizeNN(src, dst, inv_scale_x, inv_scale_y);
+        return;
+    }
+    int k;
+    int isx;
+    int isy;
+    int idx;
+    int idy;
+
+    int xmin = 0;
+    int xmax = dsize.width;
+    int width = dsize.width * cn;
+    bool area_mode = interpolation == INTER_AREA;
+    bool fixpt = depth == CV_8U;
+    float ifx;
+    float ify;
+    ResizeFunc func = nullptr;
+    int ksize = 0;
+    int ksize3;
+    if (interpolation == INTER_CUBIC) {
+        ksize = 4, func = cubic_tab[depth];
+    } else if (interpolation == INTER_LINEAR) {
+        ksize = 2, func = linear_tab[depth];
+    } else {
+        printf("Unknown interpolation method");
+    }
+    ksize3 = ksize / 2;
+    AutoBuffer<uchar> _buffer((width + dsize.height) * (sizeof(int) + sizeof(float) * ksize));
+    int *xofs = (int *)_buffer.data();
+    int *yofs = xofs + width;
+    float *alphax = reinterpret_cast<float *>(yofs + dsize.height);
+    short *ialphax = reinterpret_cast<short *>(alphax);
+    short *ibetax = ialphax + width * ksize;
+    float *betax = alphax + width * ksize;
+    float cbuf[MAX_ESIZE1] = {0};
+
+    for (idx = 0; idx < dsize.width; idx++) {
+        if (!area_mode) {
+            ifx = (float)((idx + 0.5) * scale_x - 0.5);  // 0.5是为了对齐调整坐标
+            isx = cvFloor(ifx);
+            ifx -= isx;
+        } else {
+            isx = cvFloor(idx * scale_x);
+            ifx = (float)((idx + 1) - (isx + 1) * inv_scale_x);
+            ifx = ifx <= 0 ? 0.f : ifx - cvFloor(ifx);
+        }
+
+        if (isx < ksize3 - 1) {
+            xmin = idx + 1;
+            if (isx < 0 && (interpolation != INTER_CUBIC && interpolation != INTER_LANCZOS4))
+                ifx = 0, isx = 0;
+        }
+
+        if (isx + ksize3 >= src_width) {
+            if (isx >= src_width - 1 && (interpolation != INTER_CUBIC && interpolation != INTER_LANCZOS4))
+                ifx = 0, isx = src_width - 1;
+            xmax = std::min(xmax, idx);
+        }
+
+        for (k = 0, isx *= cn; k < cn; k++)
+            xofs[idx * cn + k] = isx + k;
+
+        if (interpolation == INTER_CUBIC)
+            _interpolateCubic(ifx, cbuf);
+        else {
+            cbuf[0] = 1.f - ifx;
+            cbuf[1] = ifx;
+        }
+        if (fixpt) {
