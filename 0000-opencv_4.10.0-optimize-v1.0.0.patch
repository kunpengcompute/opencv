+
+            for (; w < width; ++w) {
+                uint16_t result[3];
+                const uint8_t *pixelUp;
+                const uint8_t *pixelDown;
+                const uint8_t *pixelMid;
+                uint8_t *dstPixel;
+
+                uint16_t coef_single = ky[mid];
+                pixelMid = src_data + lineNum * srcStep + w * 3;  // 3
+                result[0] = coef_single * static_cast<uint16_t>(pixelMid[0]);
+                result[1] = coef_single * static_cast<uint16_t>(pixelMid[1]);
+                result[2] = coef_single * static_cast<uint16_t>(pixelMid[2]);  // 2
+
+                for (int shift = 1; shift < (ksizeY + 1) / 2; ++shift) {  // 2
+                    int rowUpIndex = abs(lineNum - shift);
