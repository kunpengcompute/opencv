+    for (int i = 0; i <= numPixels - vectorSize; i += vectorSize) {
+        uint8x16x3_t v_rgb = vld3q_u8(src + i * srcChannels);
+        vst3q_u8(dst + i * dstChannels, {v_rgb.val[2], v_rgb.val[1], v_rgb.val[0]});
+    }
+
+    src = src + (numPixels / vectorSize) * vectorSize;
+    for (int i = (numPixels / vectorSize) * vectorSize; i < numPixels; i++, src += srcChannels, dst += dstChannels) {
+        dst[blueIdx] = src[0];
+        dst[1] = src[1];
+        dst[blueIdx ^ 2] = src[2];
+    }
