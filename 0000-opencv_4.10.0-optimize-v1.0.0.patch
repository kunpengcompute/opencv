+static void BGR2Gray_neon(const uint8_t *bgr, uint8_t *gray, int numPixels)
+{
+    uint8x8_t r = vdup_n_u8(77);
+    uint8x8_t g = vdup_n_u8(150);
+    uint8x8_t b = vdup_n_u8(29);
