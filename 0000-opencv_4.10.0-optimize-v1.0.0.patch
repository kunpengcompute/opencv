+static inline uint16x8x3_t vGaussianBlur3Naba(
+    const uint8_t *srcRow0, const uint8_t *srcRow1, const uint8_t *srcRow2, int w, const uint16_t *ky)
+{
+    uint16x8x3_t vConvResult;
+
+    uint8x8x3_t rgbRow0 = vld3_u8(srcRow0 + w * 3);
+    uint8x8x3_t rgbRow1 = vld3_u8(srcRow1 + w * 3);
+    uint8x8x3_t rgbRow2 = vld3_u8(srcRow2 + w * 3);
+
+    uint16x8_t kmid = vdupq_n_u16(ky[1]);
+    uint16x8_t kside = vdupq_n_u16(ky[0]);
+
+    vConvResult.val[0] = vmulq_u16(vmovl_u8(rgbRow0.val[0]), kside);
+    vConvResult.val[1] = vmulq_u16(vmovl_u8(rgbRow0.val[1]), kside);
+    vConvResult.val[2] = vmulq_u16(vmovl_u8(rgbRow0.val[2]), kside);  // 2
+
+    vConvResult.val[0] = vmlaq_u16(vConvResult.val[0], vmovl_u8(rgbRow1.val[0]), kmid);
+    vConvResult.val[1] = vmlaq_u16(vConvResult.val[1], vmovl_u8(rgbRow1.val[1]), kmid);
+    vConvResult.val[2] = vmlaq_u16(vConvResult.val[2], vmovl_u8(rgbRow1.val[2]), kmid);  // 2
+
+    vConvResult.val[0] = vmlaq_u16(vConvResult.val[0], vmovl_u8(rgbRow2.val[0]), kside);
+    vConvResult.val[1] = vmlaq_u16(vConvResult.val[1], vmovl_u8(rgbRow2.val[1]), kside);
+    vConvResult.val[2] = vmlaq_u16(vConvResult.val[2], vmovl_u8(rgbRow2.val[2]), kside);  // 2
+
+    return vConvResult;
+}
