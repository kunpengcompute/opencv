+        (code == COLOR_BGR2RGB);
+    if (!isSuport) {
+        return 2;
+    }
+    switch (code) {
+        case COLOR_BGR2GRAY:
+        case COLOR_BGRA2GRAY:
+        case COLOR_RGB2GRAY:
+        case COLOR_RGBA2GRAY:
