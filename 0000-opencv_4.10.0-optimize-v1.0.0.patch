+template <typename T, typename WT, typename AT, class VecOp>
+struct _HResizeCubic {
+    using value_type = T;
+    using buf_type = WT;
+    using alpha_type = AT;
+
+    void operator()(const T **src, WT **dst, int count, const int *xofs, const AT *alphax, int swidth, int dwidth,
+                    int cn, int xmin, int xmax) const
+    {
+        VecOp vecOp;
+        int dx0 = vecOp(src, dst, count, xofs, alphax, swidth, dwidth, cn, xmin, xmax);
+        for (int k = 0; k < count; k++) {
+            const T *S = src[k];
+            WT *D = dst[k];
+            int idx = dx0;
+            int limit = xmin;
+            for (;;) {
+                for (; idx < limit; idx++, alphax += 4) {
+                    int j;
+                    int isx = xofs[idx] - cn;
+                    WT value = 0;
+                    for (j = 0; j < 4; j++) {
+                        int tmp = isx + j * cn;
+                        if (static_cast<unsigned>(tmp) >= static_cast<unsigned>(swidth)) {
+                            while (tmp < 0) {
+                                tmp += cn;
+                            }
+                            while (tmp >= swidth) {
+                                tmp -= cn;
+                            }
+                        }
+                        value += S[tmp] * alphax[j];
+                    }
+                    D[idx] = value;
+                }
+                if (limit == dwidth) {
+                    break;
+                }
+                for (; idx < xmax; idx++, alphax += 4) {
+                    int isx = xofs[idx];
+                    // 2 3数组下标
+                    D[idx] = S[isx - cn] * alphax[0] + S[isx] * alphax[1] + S[isx + cn] * alphax[2] +
+                             S[isx + cn * 2] * alphax[3];
+                }
+                limit = dwidth;
+            }
+            alphax -= dwidth * 4;
+        }
+    }
+};
+
+template <typename T, typename WT, typename AT, class CastOp, class VecOp>
+struct _VResizeCubic {
+    using value_type = T;
+    using buf_type = WT;
+    using alpha_type = AT;
+
+    void operator()(const WT **src, T *dst, const AT *betax, int width) const
+    {
+        WT b0 = betax[0];
+        WT b1 = betax[1];
+        WT b2 = betax[2];
+        WT b3 = betax[3];
+        const WT *S0 = src[0];
+        const WT *S1 = src[1];
+        const WT *S2 = src[2];
+        const WT *S3 = src[3];
+        CastOp castOp;
+        VecOp vecOp;
+
+        int x = vecOp(src, dst, betax, width);
+        for (; x < width; x++) {
+            dst[x] = castOp(S0[x] * b0 + S1[x] * b1 + S2[x] * b2 + S3[x] * b3);
+        }
+    }
+};
