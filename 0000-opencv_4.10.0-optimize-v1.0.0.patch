                  double inv_scale_x, double inv_scale_y, int interpolation )
 {
+
+    int retcode = cv::kcv_resize(_src,_dst,dsize,inv_scale_x,inv_scale_y,interpolation);
+    if(retcode == 0 || retcode == 1)
+        return;
     CV_INSTRUMENT_REGION();
 
