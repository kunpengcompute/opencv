+class ParallelLoopBodyWrapperContext {
+public:
+    ParallelLoopBodyWrapperContext(const cv::ParallelLoopBody &_body, const cv::Range &rx, double nps)
+        : isRngUsed(false), hasException(false)
+    {
+        whRge = rx;
+        body = &_body;
+        double len = whRge.end - whRge.start;
+        nstripes = cvRound(nps <= 0 ? len : MIN(MAX(nps, 1.), len));
+        rng = cv::theRNG();
+    }
+    void finalize()
+    {
+        if (isRngUsed) {
+            cv::theRNG() = rng;
+            cv::theRNG().next();
+        }
+    }
+    ~ParallelLoopBodyWrapperContext()
+    {}
+    const cv::ParallelLoopBody *body;
+    cv::RNG rng;
+    cv::Range whRge;
+    mutable bool isRngUsed;
+    bool hasException;
+    int nstripes;
+    cv::String excep_msg;
+    void rcdExcept(const cv::String &msg)
+    {
+        (void)msg;
+#ifndef CV_THREAD_SANITIZER
+#endif
+    }
+private:
+    ParallelLoopBodyWrapperContext(const ParallelLoopBodyWrapperContext &);
+    ParallelLoopBodyWrapperContext &operator=(const ParallelLoopBodyWrapperContext &);
+};
+
+class ParallelLoopBodyWrapper : public cv::ParallelLoopBody {
+public:
+    explicit ParallelLoopBodyWrapper(ParallelLoopBodyWrapperContext &ctx_) : context(ctx_)
+    {}
+    ~ParallelLoopBodyWrapper()
+    {}
+    void operator()(const cv::Range &sr) const CV_OVERRIDE
+    {
+        cv::theRNG() = context.rng;
+
+        cv::Range r;
+        cv::Range whRge = context.whRge;
+        int nstripes = context.nstripes;
+        r.start = (int)(whRge.start +
+                        ((uint64)sr.start * (whRge.end - whRge.start) + nstripes / 2) / nstripes);
+        r.end = sr.end >= nstripes
+                    ? whRge.end
+                    : (int)(whRge.start +
+                            ((uint64)sr.end * (whRge.end - whRge.start) + nstripes / 2) / nstripes);
+        try {
+            (*context.body)(r);
+        }
+
+        catch (const cv::Exception &e) {
+            context.rcdExcept(e.what());
+        } catch (const std::exception &e) {
+            context.rcdExcept(e.what());
+        } catch (...) {
+            context.rcdExcept("Unknown exception message");
+        }
+    }
+    cv::Range stripeRange() const
+    {
+        return cv::Range(0, context.nstripes);
+    }
+
+protected:
+    ParallelLoopBodyWrapperContext &context;
+};
+using ProxyLoopBody = ParallelLoopBodyWrapper;
