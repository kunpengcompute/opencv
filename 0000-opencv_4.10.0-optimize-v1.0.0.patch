+static void threshold_8U(InputArray _src, OutputArray _dst, double thresh, double maxval, int type)
+{
+    if (type != THRESH_BINARY) {
+        return;
+    }
+    Mat src = _src.getMat();
+    _dst.create(src.size(), src.type());
+    Mat dst = _dst.getMat();
+    const uchar *srcptr = src.ptr();
+    uchar *dstptr = dst.ptr();
+    int len = src.total() * src.channels();
+    uchar uThresh = (uchar)thresh;
+    uchar uMaxval = (uchar)maxval;
+    uint8x16_t v_thresh = vdupq_n_u8(uThresh);
+    uint8x16_t v_maxval = vdupq_n_u8(uMaxval);
+    constexpr int neonStep = 16;  // 16 128/8
+#pragma omp parallel for num_threads(20)
+    for (int i = 0; i <= len - neonStep; i += neonStep) {
+        uint8x16_t v_src = vld1q_u8(srcptr + i);
+        v_src = vcltq_u8(v_thresh, v_src);
+        uint8x16_t v_dst = vandq_u8(v_src, v_maxval);
+        vst1q_u8(dstptr + i, v_dst);
+    }
+
+    for (int i = len - len % neonStep; i < len; i++) {
+        dstptr[i] = (srcptr[i] > uThresh) ? uMaxval : 0;
+    }
+}
